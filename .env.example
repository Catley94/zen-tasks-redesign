# Client (browser) — Vite exposes only VITE_-prefixed vars to the bundle.
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server only — read by the Express backend (server/index.js), never sent to the
# browser. Do NOT prefix with VITE_ (that would inline it into the public bundle).
# Local dev: loaded via `npm run dev:server` (Node --env-file).
# Production: set it in Render's service Environment vars instead of a file.
ANTHROPIC_API_KEY=sk-ant-...
